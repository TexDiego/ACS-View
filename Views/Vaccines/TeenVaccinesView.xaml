<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             xmlns:model="clr-namespace:ACS_View.Domain.Entities"
             x:DataType="vm:VaccinesPageViewModel"
             x:Class="ACS_View.Views.Vaccines.TeenVaccinesView">

    <ContentView.Resources>
        <Style x:Key="vacinasp" TargetType="Label">
            <Setter Property="HorizontalOptions" Value="Center"/>
            <Setter Property="TextColor" Value="Black"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="LineBreakMode" Value="WordWrap"/>
        </Style>

        <Style x:Key="title" TargetType="Label">
            <Setter Property="HorizontalOptions" Value="Center"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="TextColor" Value="Black"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="LineBreakMode" Value="WordWrap"/>
        </Style>
    </ContentView.Resources>

    <VerticalStackLayout
        BindingContext="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.Vaccines}"
        x:DataType="model:Vaccines">
<!-- Vacinas adolescentes -->
                <Grid
                    RowDefinitions="*,*,*,*,*,*"
                    IsVisible="{Binding IsYoung}">

                    <!-- Hepatite B -->
                    <Border
                        IsVisible="{Binding ShowHB}"
                        Grid.Row="0"
                        Margin="15,0,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            RowDefinitions="*"
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SituacaoHBAdolescente}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="Qualquer"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <!-- Hepatite B -->
                            <Label
                                Style="{StaticResource vacinasp}"
                                Grid.Column="1"
                                Text="Hepatite B"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="HB2"/>
                                </Label.GestureRecognizers>
                                
                            </Label>

                            <Label
                                Style="{StaticResource vacinasp}"
                                Grid.Column="2"
                                Text="Única"
                                Margin="0,5,0,5"/>

                        </Grid>
                    </Border>

                    <!-- dT -->
                    <Border
                        IsVisible="{Binding ShowDT}"
                        Grid.Row="1"
                        Margin="15,15,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            RowDefinitions="*"
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SituacaoDTAdolescente}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="Qualquer"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <Label
                                Style="{StaticResource vacinasp}"
                                Grid.Column="1"
                                Text="dT"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="DT2"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label
                                Style="{StaticResource vacinasp}"
                                Grid.Row="0"
                                Grid.Column="2"
                                Text="Completar"
                                Margin="0,5,0,5"/>

                        </Grid>
                    </Border>

                    <!-- Febre amarela -->
                    <Border
                        IsVisible="{Binding ShowFebreAmarela}"
                        Grid.Row="2"
                        Margin="15,15,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            RowDefinitions="*"
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                Grid.RowSpan="1"
                                BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SituacaoFAAdolescente}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="Qualquer"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <Label
                                Style="{StaticResource vacinasp}"
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="Febre amarela"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="FA4"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label
                                Style="{StaticResource vacinasp}"
                                Grid.Row="1"
                                Grid.Column="2"
                                Text="Completar"
                                Margin="0,5,0,5"/>

                        </Grid>
                    </Border>

                    <!-- Triplice viral -->
                    <Border
                        IsVisible="{Binding ShowTripliceViral}"
                        Grid.Row="3"
                        Margin="15,15,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="{Binding SituacaoTripliceViralAdolescente}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="Qualquer"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <Label
                                Style="{StaticResource vacinasp}"
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="Tríplice viral"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="TripliceViral2"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label
                                Style="{StaticResource vacinasp}"
                                Grid.Row="0"
                                Grid.Column="2"
                                Text="Completar"
                                Margin="0,5,0,0"/>

                        </Grid>
                    </Border>

                    <!-- HPV -->
                    <Border
                        IsVisible="{Binding ShowHPV}"
                        Grid.Row="4"
                        Margin="15,15,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                Grid.RowSpan="1"
                                BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SituacaoHPVAdolescente}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="11-14 anos"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <Label
                                Style="{StaticResource vacinasp}"
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="HPV"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="HPV2"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label
                                Style="{StaticResource vacinasp}"
                                Grid.Column="2"
                                Text="Dose única"
                                Margin="0,5,0,5"/>

                        </Grid>
                    </Border>

                    <!-- ACWY -->
                    <Border
                        IsVisible="{Binding ShowACWY}"
                        Grid.Row="5"
                        Margin="15,15,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SituacaoACWYAdolescente}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="11-14 anos"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <Label
                                Style="{StaticResource vacinasp}"
                                Grid.Column="1"
                                Text="ACWY"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="ACWY"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label
                                Style="{StaticResource vacinasp}"
                                Grid.Row="0"
                                Grid.Column="2"
                                Text="Uma dose"
                                Margin="0,5,0,5"/>

                        </Grid>
                    </Border>                    

                </Grid>
    </VerticalStackLayout>
</ContentView>