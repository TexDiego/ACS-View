<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             xmlns:vo="clr-namespace:ACS_View.Domain.ValueObjects"
             x:DataType="vm:VaccinesPageViewModel"
             x:Class="ACS_View.Views.Vaccines.AdultVaccinesView">

    <VerticalStackLayout
        BindingContext="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.Vaccines}"
        x:DataType="vm:VaccineSchedulePresentation">
                <!-- Vacinas adultos -->
                <Grid
                    RowDefinitions="*,*,*,*,*,*,*"
                    IsVisible="{Binding IsAdult}">

                    <!-- Hepatite B -->
                    <Border
                        IsVisible="{Binding ShowHBAdulto}"
                        Grid.Row="0"
                        Margin="15,0,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            RowDefinitions="*"
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SituacaoHepatiteBAdulto}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="Adulto"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Column="1"
                                Text="Hepatite B"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="{x:Static vo:VaccineDoseKeys.HepatiteBAdulto}"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Column="2"
                                Text="Completar"
                                Margin="0,5,0,5"/>

                        </Grid>
                    </Border>

                    <!-- dT -->
                    <Border
                        IsVisible="{Binding ShowdTAdulto}"
                        Grid.Row="1"
                        Margin="15,15,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            RowDefinitions="*"
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SituacaoDTAdulto}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="Adulto"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Column="1"
                                Text="dT"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="{x:Static vo:VaccineDoseKeys.DtAdulto}"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Row="0"
                                Grid.Column="2"
                                Text="Completar"
                                Margin="0,5,0,5"/>

                        </Grid>
                    </Border>

                    <!-- Febre amarela -->
                    <Border
                        IsVisible="{Binding ShowFebreAmarelaAdulto}"
                        Grid.Row="2"
                        Margin="15,15,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            RowDefinitions="*"
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                Grid.RowSpan="1"
                                BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SituacaoFebreAmarelaAdulto}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="Adulto"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="Febre amarela"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="{x:Static vo:VaccineDoseKeys.FebreAmarelaAdulto}"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Row="1"
                                Grid.Column="2"
                                Text="Completar"
                                Margin="0,5,0,5"/>

                        </Grid>
                    </Border>

                    <!-- HPV -->
                    <Border
                        IsVisible="{Binding ShowHPVAdulto}"
                        Grid.Row="3"
                        Margin="15,15,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SituacaoHPVAdulto}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="9-45 anos"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="HPV"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="{x:Static vo:VaccineDoseKeys.HpvAdulto}"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Column="2"
                                Text="Completar"
                                Margin="0,5,0,5"/>

                        </Grid>
                    </Border>

                    <!-- Triplice viral 1 -->
                    <Border
                        IsVisible="{Binding ShowTripliceViral1Adulto}"
                        Grid.Row="4"
                        Margin="15,15,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SituacaoTripliceViral1Adulto}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="20-29 anos"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Column="1"
                                Text="Tríplice viral"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="{x:Static vo:VaccineDoseKeys.TripliceViralAdulto20A29}"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Column="2"
                                Text="Uma dose"
                                Margin="0,5,0,5"/>

                        </Grid>
                    </Border>

                    <!-- Triplice viral 2 -->
                    <Border
                        IsVisible="{Binding ShowTripliceViral2Adulto}"
                        Grid.Row="5"
                        Margin="15,15,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SituacaoTripliceViral2Adulto}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="30-59 anos"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Column="1"
                                Text="Tríplice viral"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="{x:Static vo:VaccineDoseKeys.TripliceViralAdulto30A59}"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Column="2"
                                Text="Uma dose"
                                Margin="0,5,0,5"/>

                        </Grid>
                    </Border>
                    
                    <!-- dTpa -->
                    <Border
                        IsVisible="{Binding ShowdTpaAdulto}"
                        Grid.Row="6"
                        Margin="15,15,15,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            ColumnDefinitions="*,*,*"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SituacaodTpaAdulto}"
                                StrokeShape="RoundRectangle 20">

                                <Label
                                    Text="18 anos +"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="White"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            </Border>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Column="1"
                                Text="dTpa"
                                Margin="0,5,0,5">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVaccineInfo}"
                                        CommandParameter="{x:Static vo:VaccineDoseKeys.DtpaAdulto}"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label
                                Style="{StaticResource VaccineItems}"
                                Grid.Column="2"
                                Text="Uma dose"
                                Margin="0,5,0,5"/>

                        </Grid>
                    </Border>   

                </Grid>
    </VerticalStackLayout>
</ContentView>