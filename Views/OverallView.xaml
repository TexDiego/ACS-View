<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             x:DataType="vm:OverallViewModel"
             x:Class="ACS_View.Views.OverallView"
             Title="Início"
             Style="{StaticResource PageBackground}">

    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="plus.png"
                     Command="{Binding AddCombinedMetricCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid Padding="{StaticResource PagePadding}" RowDefinitions="auto,*" RowSpacing="14">

        <Border Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource DarkBorderSoft}}"
                StrokeShape="RoundRectangle 8"
                Padding="4">
            <Grid ColumnDefinitions="*,*">
                <Border Grid.Column="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 7"
                        Padding="10,9">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding GeneralTabSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryLight}"/>
                        </DataTrigger>
                    </Border.Triggers>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchView}" CommandParameter="0"/>
                    </Border.GestureRecognizers>

                    <Label
                        Text="Métricas"
                        FontSize="15"
                        HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}"
                        FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding GeneralTabSelected}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource Primary}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 7"
                        Padding="10,9">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding HealthTabSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryLight}"/>
                        </DataTrigger>
                    </Border.Triggers>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchView}" CommandParameter="1"/>
                    </Border.GestureRecognizers>

                    <Label
                        Text="Saúde"
                        FontSize="15"
                        HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}"
                        FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding HealthTabSelected}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource Primary}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
            </Grid>
        </Border>

        <ContentView
            x:Name="Metrics"
            Grid.Row="1"
            Content="{Binding CurrentView}"/>
    </Grid>
</ContentPage>
