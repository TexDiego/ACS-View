<?xml version="1.0" encoding="utf-8" ?>
<tk:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:ACS_View.Domain.Entities"
    xmlns:tk="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:ACS_View.ViewModels"
    x:Class="ACS_View.Views.VisitPage"
    x:TypeArguments="models:Visits"
    WidthRequest="{x:Static vm:BaseViewModel.DefaultPopupWidth}"
    BackgroundColor="Transparent"
    Padding="0">

    <Border>
        <VerticalStackLayout BackgroundColor="{x:AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}" x:Name="layoutGrid" Spacing="16" Padding="10">
            <VerticalStackLayout Spacing="4">
                <Label Text="Registrar visita" Style="{StaticResource PageTitle}" FontSize="22" HorizontalTextAlignment="Center"/>
                <Label Text="Informe o desfecho da visita" Style="{StaticResource BodyMuted}" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout BackgroundColor="{StaticResource PageBackground}" x:Name="Descricao" Spacing="4">
                <RadioButton BackgroundColor="Transparent" GroupName="DescricaoVisita" Content="Realizada" IsChecked="True" CheckedChanged="RadioButton_CheckedChanged"/>
                <RadioButton BackgroundColor="Transparent"  GroupName="DescricaoVisita" Content="Ausente" CheckedChanged="RadioButton_CheckedChanged"/>
                <RadioButton BackgroundColor="Transparent"  GroupName="DescricaoVisita" Content="Recusada" CheckedChanged="RadioButton_CheckedChanged"/>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button
                    Text="Cancelar"
                    Style="{StaticResource GhostButton}"
                    Clicked="CancelButton_Clicked"/>

                <Button
                    Grid.Column="1"
                    x:Name="AddVisitButton"
                    Text="Registrar"
                    Style="{StaticResource PrimaryButton}"
                    Clicked="AddVisitButton_Clicked"/>
            </Grid>
        </VerticalStackLayout>
    </Border>
</tk:Popup>
