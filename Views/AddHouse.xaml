<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             xmlns:model="clr-namespace:ACS_View.Domain.Entities"
             x:DataType="vm:AddHouseViewModel"
             x:Class="ACS_View.Views.AddHouse"
             Title="Adicionar Residência">

    <Grid Padding="{StaticResource PagePadding}">
        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout
                Padding="0,0,0,76"
                Spacing="10"
                BindingContext="{Binding HouseModel}"
                x:DataType="model:House">

                <Border Style="{StaticResource FieldBorder}">
                    <Grid ColumnDefinitions="90,*,44" ColumnSpacing="8">
                        <Label Grid.Column="0" Style="{StaticResource FieldLabel}" Text="CEP"/>
                        <Entry Grid.Column="1" Text="{Binding CEP, Mode=TwoWay}" MaxLength="8" Keyboard="Numeric" Placeholder="Obrigatório" TextChanged="Entry_CEP_TextChanged"/>
                        <ImageButton
                            Grid.Column="2"
                            Source="loupe.png"
                            MaximumHeightRequest="40"
                            Style="{StaticResource SoftIconButton}"
                            Command="{Binding BindingContext.SearchCEP, Source={RelativeSource AncestorType={x:Type ContentPage}}}"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">
                    <Grid ColumnDefinitions="90,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Logradouro"/>
                        <Entry Grid.Column="1" Text="{Binding Rua, Mode=TwoWay}" Placeholder="Obrigatório"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">
                    <Grid ColumnDefinitions="90,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Número"/>
                        <Entry Grid.Column="1" Text="{Binding NumeroCasa, Mode=TwoWay}" MaxLength="5" Keyboard="Numeric"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">
                    <Grid ColumnDefinitions="90,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Complemento"/>
                        <Entry Grid.Column="1" Text="{Binding Complemento, Mode=TwoWay}" MaxLength="30"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">
                    <Grid ColumnDefinitions="90,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Bairro"/>
                        <Entry Grid.Column="1" Text="{Binding Bairro, Mode=TwoWay}" Placeholder="Obrigatório"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">
                    <Grid ColumnDefinitions="90,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Cidade"/>
                        <Entry Grid.Column="1" Text="{Binding Cidade, Mode=TwoWay}" Placeholder="Obrigatório"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">
                    <Grid ColumnDefinitions="90,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Estado"/>
                        <Entry Grid.Column="1" Text="{Binding Estado, Mode=TwoWay}" Placeholder="Obrigatório"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">
                    <Grid ColumnDefinitions="90,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Style="{StaticResource FieldLabel}" Text="País"/>
                        <Entry Grid.Column="1" Text="{Binding Pais, Mode=TwoWay}" MaxLength="20" Placeholder="Obrigatório"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator
            IsRunning="{Binding IsRunning}"
            IsVisible="{Binding IsRunning}"
            HeightRequest="60"
            WidthRequest="60"/>

        <Button
            VerticalOptions="End"
            Text="Salvar"
            Style="{StaticResource PrimaryButton}"
            Command="{Binding SalvarCommand}"/>
    </Grid>
</ContentPage>
