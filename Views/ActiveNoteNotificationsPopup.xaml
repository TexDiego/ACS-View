<?xml version="1.0" encoding="utf-8" ?>
<tk:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:tk="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:ACS_View.ViewModels"
    xmlns:dto="clr-namespace:ACS_View.Application.DTOs"
    x:Name="RootPopup"
    x:Class="ACS_View.Views.ActiveNoteNotificationsPopup"
    x:TypeArguments="dto:NoteNotificationManagementRequestDto"
    x:DataType="vm:ActiveNoteNotificationsPopupViewModel"
    WidthRequest="{Binding PopupWidth}"
    CanBeDismissedByTappingOutsideOfPopup="True"
    BackgroundColor="Transparent"
    Padding="0">

    <Border
        Style="{StaticResource CardBorder}"
        Padding="14"
        Margin="0"
        StrokeShape="RoundRectangle 8">

        <Grid RowDefinitions="auto,auto,auto" RowSpacing="12">
            <VerticalStackLayout Grid.Row="0" Spacing="10">
                <Label
                    Text="Notificações ativas"
                    Style="{StaticResource SectionTitle}"
                    HorizontalOptions="Center"/>
                <Label
                    Text="{Binding SummaryText}"
                    Style="{StaticResource BodyMuted}"
                    HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <CollectionView
                Grid.Row="1"
                ItemsSource="{Binding Notifications}"
                IsVisible="{Binding HasNotifications}"
                VerticalScrollBarVisibility="Never"
                MaximumHeightRequest="420">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:ActiveNoteNotificationDto">
                        <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="8">
                                <Label
                                    Text="{Binding Content}"
                                    Style="{StaticResource CardTitle}"
                                    FontSize="15"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="2"/>

                                <HorizontalStackLayout Spacing="4">
                                    <Label
                                        Text="Notificar em"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{AppThemeBinding Light={StaticResource Accent}, Dark={StaticResource AccentLight}}"/>
                                    <Label
                                        Text="{Binding NotifyOnText}"
                                        Style="{StaticResource BodyMuted}"
                                        FontSize="12"/>
                                </HorizontalStackLayout>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <Button
                                        Text="Reagendar"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding Source={x:Reference RootPopup}, Path=BindingContext.RescheduleCommand}"
                                        CommandParameter="{Binding .}"/>
                                    <Button
                                        Grid.Column="1"
                                        Text="Cancelar"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding Source={x:Reference RootPopup}, Path=BindingContext.CancelCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button
                Grid.Row="2"
                Text="Fechar"
                Style="{StaticResource GhostButton}"
                Clicked="CloseButton_Clicked"/>
        </Grid>
    </Border>
</tk:Popup>
