<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             x:DataType="vm:ProfileViewModel"
             x:Class="ACS_View.Views.Profile"
             Title="Perfil">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="14">
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Área pessoal" Style="{StaticResource SectionTitle}"/>
                    <Label Text="Acesse anotações e lembretes do seu acompanhamento." Style="{StaticResource BodyMuted}"/>
                    <Button Text="Abrir anotações"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding OpenNotesPage}"/>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Importação" Style="{StaticResource SectionTitle}"/>
                    <Label Text="Importe cadastros de pacientes e residências por planilha." Style="{StaticResource BodyMuted}"/>
                    <Button Text="Abrir importação"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding OpenImportDataPage}"/>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Conta" Style="{StaticResource SectionTitle}"/>
                    <Label Text="Encerre a sessão neste dispositivo." Style="{StaticResource BodyMuted}"/>
                    <Button Text="Sair"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="{StaticResource White}"
                            Command="{Binding LogoutCommand}"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
