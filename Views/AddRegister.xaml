<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             xmlns:model="clr-namespace:ACS_View.Domain.Entities"
             xmlns:enums="clr-namespace:ACS_View.Domain.Enums"
             xmlns:objects="clr-namespace:ACS_View.Domain.ValueObjects"
             xmlns:converters="clr-namespace:ACS_View.Converters"
             x:DataType="vm:AddRegisterViewModel"
             x:Class="ACS_View.Views.AddRegister"
             Style="{StaticResource PageBackground}"
             Title="Adicionar cadastro">

    <ContentPage.Resources>
        <Style x:Key="labels" TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}"/>
            <Setter Property="FontAttributes" Value="Bold"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}"/>
            <Setter Property="HorizontalOptions" Value="End"/>
        </Style>

        <ControlTemplate x:Key="RadioButtonTemplate">
            <Border
                Style="{StaticResource FieldBorder}"
                Padding="5"
                StrokeThickness="2"
                StrokeShape="RoundRectangle 10"
                HorizontalOptions="Center"
                VerticalOptions="Center">

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CheckedStates">
                            <VisualState x:Name="Checked">
                                <VisualState.Setters>
                                    <Setter Property="Stroke"
                                        Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}" />
                                    <Setter TargetName="check"
                                        Property="Opacity"
                                        Value="1" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Unchecked">
                                <VisualState.Setters>
                                    <Setter Property="Stroke"
                                        Value="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource DarkBorderSoft}}" />
                                    <Setter TargetName="check"
                                        Property="Opacity"
                                        Value="0" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
                <Grid ColumnDefinitions="auto, *" ColumnSpacing="10" BackgroundColor="Transparent" HorizontalOptions="Fill">

                    <Grid
                        Grid.Column="1"
                        HorizontalOptions="End"
                        VerticalOptions="Center">

                        <Ellipse Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}"
                                Fill="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                                WidthRequest="16"
                                HeightRequest="16"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        <Ellipse x:Name="check"
                                Fill="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}"
                                WidthRequest="8"
                                HeightRequest="8"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                    </Grid>

                    <ContentPresenter Grid.Column="0"/>
                </Grid>
            </Border>
        </ControlTemplate>

        <Style TargetType="RadioButton">
            <Setter Property="ControlTemplate"
                Value="{StaticResource RadioButtonTemplate}" />
        </Style>
    </ContentPage.Resources>
    <Grid>

        <ScrollView
            VerticalOptions="Start"
            VerticalScrollBarVisibility="Never">

            <VerticalStackLayout
                Padding="16,16,16,92"
                Spacing="10"
                BindingContext="{Binding CurrentPatient}"
                x:DataType="model:Patient">

                <Border Style="{StaticResource FieldBorder}">

                    <Grid ColumnDefinitions="auto,*">

                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource labels}"
                            Margin="0,0,10,0"
                            VerticalOptions="Center"
                            HorizontalOptions="Start"
                            Text="Nome"/>

                        <Entry
                            Grid.Row="0"
                            Grid.Column="1"
                            VerticalOptions="Center"
                            Margin="0"
                            MaxLength="70"
                            Keyboard="Text"
                            Text="{Binding Name, Mode=TwoWay}"/>

                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">

                    <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="8">
                        <Label
                            Grid.Column="0"
                            Style="{StaticResource labels}"
                            Margin="0,0,10,0"
                            VerticalOptions="Center"
                            HorizontalOptions="Start"
                            Text="Mãe:"/>

                        <Entry
                            Grid.Column="1"
                            VerticalOptions="Center"
                            Margin="0"
                            MaxLength="70"
                            Keyboard="Text"
                            Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MotherNameInput, Mode=TwoWay}"/>

                        <ImageButton
                            Grid.Column="2"
                            Source="loupe.png"
                            Style="{StaticResource SoftIconButton}"
                            HeightRequest="40"
                            WidthRequest="40"
                            Padding="9"
                            ToolTipProperties.Text="Selecionar cadastro da mãe"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectMotherCommand}"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">

                    <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="8">
                        <Label
                            Grid.Column="0"
                            Style="{StaticResource labels}"
                            Margin="0,0,10,0"
                            VerticalOptions="Center"
                            HorizontalOptions="Start"
                            Text="Pai:"/>

                        <Entry
                            Grid.Column="1"
                            VerticalOptions="Center"
                            Margin="0"
                            MaxLength="70"
                            Keyboard="Text"
                            Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.FatherNameInput, Mode=TwoWay}"/>

                        <ImageButton
                            Grid.Column="2"
                            Source="loupe.png"
                            Style="{StaticResource SoftIconButton}"
                            HeightRequest="40"
                            WidthRequest="40"
                            Padding="9"
                            ToolTipProperties.Text="Selecionar cadastro do pai"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectFatherCommand}"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">

                    <Grid ColumnDefinitions="auto,*">

                        <Label
                            Grid.Column="0"
                            Style="{StaticResource labels}"
                            Margin="0,0,10,0"
                            VerticalOptions="Center"
                            HorizontalOptions="Start"
                            Text="SUS"/>

                        <Entry
                            Grid.Column="1"
                            VerticalOptions="Center"
                            Margin="0"
                            MaxLength="15"
                            Keyboard="Numeric"
                            Text="{Binding SusNumber, Mode=TwoWay}"/>

                    </Grid>
                </Border>

                <HorizontalStackLayout
                    RadioButtonGroup.GroupName="Sexo"
                    RadioButtonGroup.SelectedValue="{Binding Sexo, Mode=TwoWay}"
                    HorizontalOptions="Center"
                    Spacing="2"
                    Margin="0"
                    Padding="0">

                    <RadioButton Content="Masculino" Value="Masculino"/>
                    <RadioButton Content="Feminino" Value="Feminino"/>
                    <RadioButton Content="Indeterminado" Value="Indeterminado"/>

                </HorizontalStackLayout>

                <Border Style="{StaticResource FieldBorder}">

                    <Grid ColumnDefinitions="auto,*">

                        <Label
                            Grid.Column="0"
                            Style="{StaticResource labels}"
                            VerticalOptions="Center"
                            HorizontalOptions="Start"
                            Text="Data de Nascimento:"/>

                        <DatePicker
                            Grid.Column="1"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"
                            Opacity="0.7"
                            VerticalOptions="Center"
                            HorizontalOptions="End"
                            FontSize="18"
                            Date="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BirthDateInput, Mode=TwoWay}"
                            Format="dd/MM/yyyy"
                            MinimumDate="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MinimumDate}"
                            MaximumDate="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MaximumDate}"/>

                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">

                    <Grid RowDefinitions="auto,auto,auto" RowSpacing="10">

                        <Grid Grid.Row="0" ColumnDefinitions="auto,*">

                            <Label
                                Grid.Column="0"
                                Style="{StaticResource labels}"
                                VerticalOptions="Center"
                                HorizontalOptions="Start"
                                Text="Bolsa Família:"/>

                            <CheckBox
                                Grid.Column="1"
                                IsChecked="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsBolsaFamiliaSelected, Mode=TwoWay}"
                                Opacity="0.7"
                                VerticalOptions="Center"/>

                        </Grid>

                        <Grid
                            Grid.Row="1"
                            ColumnDefinitions="auto,*"
                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsBolsaFamiliaSelected}">

                            <Label
                                Grid.Column="0"
                                Style="{StaticResource labels}"
                                VerticalOptions="Center"
                                HorizontalOptions="Start"
                                Text="NIS:"/>

                            <Entry
                                Grid.Column="1"
                                Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BolsaFamiliaNisInput, Mode=TwoWay, Converter={converters:NISFormatConverter}}"
                                Placeholder="Número NIS"
                                MaxLength="14"
                                Keyboard="Numeric"
                                Opacity="0.7"/>

                        </Grid>

                        <Grid
                            Grid.Row="2"
                            ColumnDefinitions="auto,*,auto,auto"
                            ColumnSpacing="8"
                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsBolsaFamiliaSelected}">

                            <Label
                                Grid.Column="0"
                                Style="{StaticResource labels}"
                                VerticalOptions="Center"
                                HorizontalOptions="Start"
                                Text="Responsável:"/>

                            <Entry
                                Grid.Column="1"
                                Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BolsaFamiliaResponsibleNameInput}"
                                Placeholder="Opcional"
                                IsReadOnly="True"
                                Opacity="0.7"/>

                            <ImageButton
                                Grid.Column="2"
                                Style="{StaticResource SoftIconButton}"
                                Source="loupe.png"
                                HeightRequest="30"
                                WidthRequest="30"
                                Padding="9"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectBolsaFamiliaResponsibleCommand}"/>

                            <ImageButton
                                Grid.Column="3"
                                Style="{StaticResource SoftIconButton}"
                                Source="remove.png"
                                HeightRequest="40"
                                WidthRequest="40"
                                Padding="9"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ClearBolsaFamiliaResponsibleCommand}"
                                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.HasBolsaFamiliaResponsible}"/>

                        </Grid>

                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">

                    <Grid RowDefinitions="auto,auto" RowSpacing="8">
                        <Grid ColumnDefinitions="*,auto">
                            <Label
                                Grid.Column="0"
                                Style="{StaticResource labels}"
                                VerticalOptions="Center"
                                HorizontalOptions="Start"
                                Text="Cadastro ativo"/>

                            <Switch
                                Grid.Column="1"
                                IsToggled="{Binding IsActive, Mode=TwoWay}"
                                OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}"
                                ThumbColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"/>
                        </Grid>

                        <Editor
                            Grid.Row="1"
                            Placeholder="Motivo do status"
                            MaxLength="200"
                            AutoSize="TextChanges"
                            Text="{Binding StatusReason, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource FieldBorder}">

                    <Grid RowDefinitions="auto,*">

                        <Label
                            Grid.Row="0"
                            Style="{StaticResource labels}"
                            Margin="20,10,0,5"
                            Text="Observação"/>

                        <Editor
                            Grid.Row="1"
                            Margin="20,0"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"
                            Opacity="0.7"
                            FontSize="18"
                            MaxLength="200"
                            AutoSize="TextChanges"
                            Text="{Binding Observacao, Mode=TwoWay}"/>

                    </Grid>

                </Border>

                <Label
                    Text="Condições de saúde"
                    FontSize="20"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    Opacity="0.8"/>

                <CollectionView ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CommonConditions}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="objects:HealthConditions">

                            <Grid RowDefinitions="auto,auto"
                                  ColumnDefinitions="*,auto"
                                  ColumnSpacing="15"
                                  Padding="10"
                                  Margin="0,5"
                                  BackgroundColor="Transparent">

                                <Label
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Text="{Binding Name}"
                                    LineBreakMode="WordWrap"
                                    FontSize="18"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"
                                    Opacity="0.8"/>

                                <CheckBox
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    IsChecked="{Binding Selected, Mode=TwoWay}"
                                    Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SwitchConditionCommand}"
                                    CommandParameter="{Binding .}"/>

                                <VerticalStackLayout
                                    Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Margin="18,4,0,0"
                                    Spacing="6"
                                    IsVisible="{Binding ShowDiabetesDetails}">

                                    <Grid ColumnDefinitions="*,auto,auto" ColumnSpacing="10">
                                        <Label
                                            Grid.Column="0"
                                            Text="Tipo"
                                            VerticalOptions="Center"
                                            LineBreakMode="WordWrap"
                                            FontSize="16"
                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"
                                            Opacity="0.75"/>

                                        <Picker
                                            Grid.Column="1"
                                            Title="Nao especificar"
                                            ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DiabetesTypeOptions}"
                                            SelectedItem="{Binding SelectedDiabetesType, Mode=TwoWay}"
                                            FontSize="14"
                                            HorizontalOptions="End"
                                            VerticalOptions="Center"
                                            WidthRequest="190"/>

                                        <ImageButton
                                            Grid.Column="2"
                                            Source="remove.png"
                                            HeightRequest="22"
                                            WidthRequest="22"
                                            VerticalOptions="Center"
                                            Aspect="AspectFit"
                                            IsVisible="{Binding HasSelectedDiabetesType}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ClearDiabetesTypeCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,auto" ColumnSpacing="15">
                                        <Label
                                            Grid.Column="0"
                                            Text="Insulinodependente"
                                            LineBreakMode="WordWrap"
                                            FontSize="16"
                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"
                                            Opacity="0.75"/>

                                        <CheckBox
                                            Grid.Column="1"
                                            IsChecked="{Binding InsulinDependentSelected, Mode=TwoWay}"
                                            Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}"/>
                                    </Grid>

                                </VerticalStackLayout>

                            </Grid>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button
                    Text="Adicionar CID"
                    HorizontalOptions="Fill"
                    Style="{StaticResource Buttons}"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenConditionsPopup}"/>

                <CollectionView
                    ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.HealthCategories}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="objects:HealthConditions">

                            <Grid ColumnDefinitions="*,auto"
                                  ColumnSpacing="15"
                                  Padding="10"
                                  Margin="0,5"
                                  BackgroundColor="Transparent">

                                <Label
                                    Grid.Column="0"
                                    Text="{Binding Name}"
                                    FontSize="18"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"
                                    Opacity="0.8"
                                    HorizontalOptions="Start"/>

                                <ImageButton
                                    Grid.Column="1"
                                    Source="remove.png"
                                    HeightRequest="20"
                                    WidthRequest="20"
                                    Margin="0,0,5,0"
                                    Aspect="AspectFit"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveConditionCommand}"
                                    CommandParameter="{Binding .}"/>

                            </Grid>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

        </ScrollView>

        <Button
            Margin="10"
            VerticalOptions="End"
            Style="{StaticResource Buttons}"
            Text="Salvar"
            Command="{Binding RegisterCommand}"/>

    </Grid>

</ContentPage>
