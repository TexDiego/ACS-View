<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             xmlns:model="clr-namespace:ACS_View.Domain.Entities"
             x:DataType="vm:AllVisitsViewModel"
             x:Class="ACS_View.Views.AllVisits"
             Shell.NavBarIsVisible="True"
             Title="Visitas">

    <Grid Padding="{StaticResource PagePadding}" RowDefinitions="*,auto" RowSpacing="14">

        <CollectionView
            Grid.Row="0"
            ItemsSource="{Binding VisitsList}"
            ItemsUpdatingScrollMode="KeepLastItemInView"
            VerticalScrollBarVisibility="Never">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:Visits">
                    <Border Style="{StaticResource CardBorder}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToHouseCommand}"
                                CommandParameter="{Binding Id}" />
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="*,44" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label
                                    Text="{Binding Date, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                    Style="{StaticResource CardTitle}"/>

                                <Label
                                    Text="{Binding Address}"
                                    Style="{StaticResource BodyMuted}"/>

                                <Label
                                    Text="{Binding Description}"
                                    TextColor="{StaticResource Accent}"
                                    FontSize="13"
                                    FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <ImageButton
                                Grid.Column="1"
                                Source="bin"
                                HeightRequest="25"
                                WidthRequest="25"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteVisit}"
                                CommandParameter="{Binding Id}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0">
            <VerticalStackLayout Spacing="10">
                <Label Text="Sugestões de visitas" Style="{StaticResource SectionTitle}"/>

                <CarouselView
                    ItemsSource="{Binding HouseList}"
                    PeekAreaInsets="22"
                    IsBounceEnabled="True"
                    IsSwipeEnabled="True"
                    HeightRequest="112">

                    <CarouselView.ItemTemplate>
                        <DataTemplate x:DataType="model:House">
                            <Border
                                Stroke="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource DarkBorderSoft}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceMuted}, Dark={StaticResource DarkSurfaceMuted}}"
                                StrokeShape="RoundRectangle 8"
                                Padding="12"
                                Margin="4,0">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToHouseCommand}"
                                        CommandParameter="{Binding CasaId}" />
                                </Border.GestureRecognizers>

                                <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                    <Label Text="{Binding Rua}" Style="{StaticResource CardTitle}" FontSize="15"/>
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="Número" Style="{StaticResource BodyMuted}"/>
                                        <Label Text="{Binding NumeroCasa}" Style="{StaticResource BodyMuted}" FontAttributes="Bold"/>
                                    </HorizontalStackLayout>
                                    <Label
                                        Text="{Binding Complemento}"
                                        IsVisible="{Binding PossuiComplemento}"
                                        Style="{StaticResource BodyMuted}"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CarouselView.ItemTemplate>
                </CarouselView>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
