<?xml version="1.0" encoding="utf-8" ?>
<tk:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:tk="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:ACS_View.ViewModels"
    x:Class="ACS_View.Views.VaccinesInfo"
    x:DataType="vm:VaccinesInfoViewModel"
    WidthRequest="{Binding PopupWidth}"
    BackgroundColor="Transparent"
    Padding="0"
    CanBeDismissedByTappingOutsideOfPopup="True">

    <Border
        Style="{StaticResource CardBorder}"
        Padding="14"
        Margin="0"
        StrokeShape="RoundRectangle 8">

        <VerticalStackLayout Spacing="12">
            <VerticalStackLayout Spacing="4">
                <Label
                    Text="{Binding VaccineName}"
                    Style="{StaticResource SectionTitle}"
                    HorizontalTextAlignment="Center"/>

                <Label
                    Text="{Binding DoseName}"
                    Style="{StaticResource BodyMuted}"
                    HorizontalTextAlignment="Center"/>

                <Border
                    Padding="10,5"
                    StrokeShape="RoundRectangle 16"
                    Stroke="{Binding StatusColor}"
                    BackgroundColor="Transparent"
                    HorizontalOptions="Center">
                    <Label
                        Text="{Binding StatusText}"
                        Style="{StaticResource BodyMuted}"
                        TextColor="{Binding StatusColor}"
                        FontAttributes="Bold"/>
                </Border>
            </VerticalStackLayout>

            <BoxView
                Color="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource DarkBorderSoft}}"
                HeightRequest="1"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Idade" Style="{StaticResource FieldLabel}"/>
                    <Label Text="{Binding AgeLabel}" Style="{StaticResource BodyMuted}"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="Registro" Style="{StaticResource FieldLabel}"/>
                    <Label Text="{Binding ApplicationDateText}" Style="{StaticResource BodyMuted}"/>
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Spacing="2">
                <Label Text="Calendario" Style="{StaticResource FieldLabel}"/>
                <Label Text="{Binding RecommendedText}" Style="{StaticResource BodyMuted}"/>
                <Label Text="{Binding DeadlineText}" Style="{StaticResource BodyMuted}"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="2">
                <Label Text="Doencas evitadas" Style="{StaticResource FieldLabel}"/>
                <Label
                    Text="{Binding DiseaseDescription}"
                    Style="{StaticResource BodyMuted}"
                    FontAttributes="Italic"
                    LineBreakMode="WordWrap"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="2" IsVisible="{Binding HasLotNumber}">
                <Label Text="Lote" Style="{StaticResource FieldLabel}"/>
                <Label Text="{Binding LotNumber}" Style="{StaticResource BodyMuted}"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="2" IsVisible="{Binding HasNotes}">
                <Label Text="Observacao" Style="{StaticResource FieldLabel}"/>
                <Label
                    Text="{Binding Notes}"
                    Style="{StaticResource BodyMuted}"
                    LineBreakMode="WordWrap"/>
            </VerticalStackLayout>

            <Button
                Text="Fechar"
                Style="{StaticResource GhostButton}"
                Clicked="CloseButton_Clicked"/>
        </VerticalStackLayout>
    </Border>
</tk:Popup>
