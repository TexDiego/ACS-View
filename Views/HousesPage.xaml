<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             xmlns:dto="clr-namespace:ACS_View.Application.DTOs"
             xmlns:controls="clr-namespace:ACS_View.Controls"
             x:DataType="vm:HousesPageViewModel"
             x:Class="ACS_View.Views.HousesPage"
             Shell.NavBarIsVisible="True"
             Style="{StaticResource PageBackground}"
             Title="Residências">

    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="addhouse.png" Command="{Binding NewHouseCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid Padding="{StaticResource PagePadding}" RowDefinitions="auto,auto,*">

        <Border Grid.Row="0" Style="{StaticResource SearchPanel}">
            <SearchBar
                Margin="0,0,0,-1"
                Placeholder="Buscar rua ou número"
                Text="{Binding SearchText, Mode=TwoWay}"
                MaxLength="30"
                TextChanged="SearchBar_TextChanged"/>
        </Border>

        <Grid ColumnDefinitions="*,*" Grid.Row="1" Margin="4,-6,4,10" HorizontalOptions="Fill">
            <Label
                Grid.Column="0"
                HorizontalOptions="Start"
                Text="{Binding FilterSummary}"
                Style="{StaticResource BodyMuted}"
                IsVisible="{Binding HasActiveFilters}"/>

            <Label
                Grid.Column="1"
                HorizontalOptions="End"
                Text="Remover filtros"
                Style="{StaticResource BodyMuted}"
                TextColor="{AppThemeBinding Light={StaticResource Accent}, Dark={StaticResource AccentLight}}"
                IsVisible="{Binding HasActiveFilters}">

                <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding ClearFiltersCommand}"/>
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <CollectionView
            x:Name="HousesCollectionView"
            Grid.Row="2"
            ItemsSource="{Binding Houses}"
            SelectionMode="None"
            VerticalScrollBarVisibility="{OnPlatform WinUI=Always, Default=Never}"
            Scrolled="CollectionView_Scrolled"
            RemainingItemsThreshold="5"
            RemainingItemsThresholdReachedCommand="{Binding LoadMoreHousesCommand}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:HouseListItemDto">
                    <Border Style="{StaticResource CardBorder}" Padding="0">
                            <Grid
                                ColumnDefinitions="*,auto"
                                ColumnSpacing="12"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">
                                <VerticalStackLayout Grid.Column="0" Spacing="5" Margin="10">
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.FamilyCommand}"
                                            CommandParameter="{Binding CasaId}"/>
                                    </VerticalStackLayout.GestureRecognizers>

                                    <Label Text="{Binding Rua}" Style="{StaticResource CardTitle}"/>
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="Número" Style="{StaticResource BodyMuted}"/>
                                        <Label Text="{Binding NumeroCasa}" Style="{StaticResource BodyMuted}" FontAttributes="Bold"/>
                                        <Label Text="{Binding Complemento}" Style="{StaticResource BodyMuted}"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <HorizontalStackLayout
                                    Grid.Column="1"
                                    Spacing="10"
                                    Margin="0,0,10,0"
                                    VerticalOptions="Center">

                                    <ImageButton
                                        Source="pencil.png"
                                        ToolTipProperties.Text="Editar"
                                        MaximumHeightRequest="28"
                                        MaximumWidthRequest="28"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCommand}"
                                        CommandParameter="{Binding .}"/>

                                    <ImageButton
                                        Source="bin.png"
                                        ToolTipProperties.Text="Excluir"
                                        MaximumHeightRequest="28"
                                        MaximumWidthRequest="28"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}"
                                        CommandParameter="{Binding CasaId}"/>
                                </HorizontalStackLayout>
                            </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding SkeletonItems}"
            IsVisible="{Binding IsLoading}"
            InputTransparent="True"
            BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <controls:ShimmerSkeletonRow ShowTrailingBlock="False" ShowSecondaryLine="True"/>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator
            Grid.Row="2"
            IsVisible="{Binding IsLoadingMore}"
            IsRunning="{Binding IsLoadingMore}"
            VerticalOptions="End"
            HorizontalOptions="Center"
            Margin="0,0,0,52"/>

        <Border Grid.RowSpan="3" Style="{StaticResource CountPill}">
            <Label
                Text="{Binding TotalHouses, StringFormat='{0} registros encontrados'}"
                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}"
                FontSize="13"
                FontAttributes="Bold"/>
        </Border>

        <ImageButton
            x:Name="BackToTopButton"
            Grid.RowSpan="3"
            Style="{StaticResource FloatingBackToTopButton}"
            Clicked="BackToTopButton_Clicked"/>
    </Grid>
</ContentPage>
