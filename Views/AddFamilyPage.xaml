<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             xmlns:model="clr-namespace:ACS_View.Domain.ValueObjects"
             x:DataType="vm:AddFamilyViewModel"
             x:Class="ACS_View.Views.AddFamilyPage"
             Style="{StaticResource PageBackground}"
             Title="Adicionar Família">

    <Grid Padding="16" RowDefinitions="auto,*">
        <Border Grid.Row="0" Style="{StaticResource CardBorder}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Indivíduo" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource SearchPanel}" Margin="0">
                    <Entry
                        x:Name="Entry_Search"
                        Placeholder="Buscar pessoa"
                        HorizontalTextAlignment="Center"
                        TextChanged="Entry_Search_TextChanged"/>
                </Border>

                <ScrollView
                    x:Name="Scroll_View_Search"
                    IsVisible="{Binding HasSearchResults}"
                    MaximumHeightRequest="210">
                    <CollectionView ItemsSource="{Binding PessoasPesquisadas}" ItemsLayout="VerticalList">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:Pessoa">
                                <Border
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceMuted}, Dark={StaticResource DarkSurfaceMuted}}"
                                    Stroke="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource DarkBorderSoft}}"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="10"
                                    Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="*,44">
                                        <Label Grid.Column="0" Text="{Binding Nome}" Style="{StaticResource CardTitle}" FontSize="15" VerticalOptions="Center"/>
                                        <ImageButton
                                            Grid.Column="1"
                                            Source="add.png"
                                            MaximumHeightRequest="40"
                                            Style="{StaticResource SoftIconButton}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AddPersonCommand}"
                                            CommandParameter="{Binding Id}"
                                            Clicked="ImageButton_Clicked"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </ScrollView>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Responsavel familiar" Style="{StaticResource SectionTitle}"/>
                    <Picker
                        Title="Selecione o responsavel"
                        ItemsSource="{Binding Pessoas}"
                        ItemDisplayBinding="{Binding Nome}"
                        SelectedItem="{Binding ResponsiblePerson, Mode=TwoWay}"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Pessoas}" Margin="0,2,0,70">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:Pessoa">
                    <Border Style="{StaticResource CardBorder}">
                        <Grid ColumnDefinitions="*,44">
                            <Label Grid.Column="0" Text="{Binding Nome}" Style="{StaticResource CardTitle}" FontSize="15" VerticalOptions="Center"/>
                            <ImageButton
                                Grid.Column="1"
                                Source="removeperson.png"
                                MaximumHeightRequest="40"
                                Style="{StaticResource DangerSoftIconButton}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}"
                                CommandParameter="{Binding Id}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button
            Grid.RowSpan="2"
            Text="Salvar"
            Style="{StaticResource Buttons}"
            VerticalOptions="End"
            Command="{Binding SalvarCommand}"/>
    </Grid>
</ContentPage>
