<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             xmlns:model="clr-namespace:ACS_View.Domain.Entities"
             xmlns:converter="clr-namespace:ACS_View.Converters"
             x:DataType="vm:NotesPageViewModel"
             x:Class="ACS_View.Views.NotesPage"
             Title="Anotações">

    <RefreshView Command="{Binding Refresh}" IsRefreshing="{Binding IsLoading}">
        <Grid RowDefinitions="auto,*" Padding="{StaticResource PagePadding}" RowSpacing="12">

            <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Nova anotação" Style="{StaticResource SectionTitle}"/>
                    <Editor
                        BindingContext="{Binding Note}"
                        x:DataType="model:Note"
                        Text="{Binding Content, Mode=TwoWay}"
                        Placeholder="Digite uma observação"
                        MaxLength="500"
                        MinimumHeightRequest="110"
                        AutoSize="TextChanges"/>
                    <Button Text="Adicionar anotação" Style="{StaticResource Buttons}" Command="{Binding SalvarNota}"/>
                </VerticalStackLayout>
            </Border>

            <CollectionView
                Grid.Row="1"
                x:Name="NotesCollectionView"
                ItemsSource="{Binding Notes}"
                VerticalScrollBarVisibility="Never"
                Scrolled="CollectionView_Scrolled">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:Note">
                        <Border Style="{StaticResource CardBorder}" Padding="0">
                            <SwipeView>
                                <SwipeView.LeftItems>
                                    <SwipeItem
                                        Style="{StaticResource DangerSwipeItem}"
                                        Text="Excluir"
                                        IconImageSource="bin.png"
                                        Command="{Binding Source={x:Reference NotesCollectionView}, Path=BindingContext.DeleteCommand}"
                                        CommandParameter="{Binding Id}"/>
                                </SwipeView.LeftItems>

                                <SwipeView.RightItems>
                                    <SwipeItem
                                        Text="Notificação"
                                        IconImageSource="notification.png"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource DarkPrimaryLight}}"
                                        Command="{Binding Source={x:Reference NotesCollectionView}, Path=BindingContext.AddNotification}"
                                        CommandParameter="{Binding Id}"/>
                                </SwipeView.RightItems>

                                <VerticalStackLayout 
                                    Spacing="9" 
                                    Padding="10,5"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">
                                    <Label Text="{Binding Content}" Style="{StaticResource CardTitle}" FontSize="16"/>

                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="Criado em" TextColor="{AppThemeBinding Light={StaticResource Accent}, Dark={StaticResource AccentLight}}" FontSize="13" FontAttributes="Bold"/>
                                        <Label Text="{Binding CreationDate, StringFormat='{0:dd/MM/yyyy HH:mm}'}" Style="{StaticResource BodyMuted}"/>
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="4" IsVisible="{Binding NotifyOn, Converter={converter:NullValueToBoolConverter}}">
                                        <Label Text="Notificar em" TextColor="{AppThemeBinding Light={StaticResource Accent}, Dark={StaticResource AccentLight}}" FontSize="13" FontAttributes="Bold"/>
                                        <Label Text="{Binding NotifyOn, StringFormat='{0:dd/MM/yyyy HH:mm}'}" Style="{StaticResource BodyMuted}"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </SwipeView>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ImageButton
                x:Name="BackToTopButton"
                Grid.RowSpan="3"
                Style="{StaticResource FloatingBackToTopButton}"
                Clicked="BackToTopButton_Clicked"/>
        </Grid>
    </RefreshView>
</ContentPage>
