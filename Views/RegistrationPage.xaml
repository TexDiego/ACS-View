<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             x:Class="ACS_View.Views.RegistrationPage"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}"
             Shell.TabBarIsVisible="False"
             Title="Cadastre-se">

    <VerticalStackLayout Margin="10">
        <Border
            StrokeShape="RoundRectangle 10"
            Padding="10"
            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
            Stroke="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource DarkBorderSoft}}">

            <VerticalStackLayout>
                <Entry
                    x:Name="DisplayNameEntry"
                    FontSize="16"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"
                    Placeholder="Digite seu nome..."/>

                <Entry
                    x:Name="UsernameEntry"
                    FontSize="16"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"
                    Placeholder="Nome de usuário..."/>

                <Label
                    Text=""
                    FontSize="14"/>

                <Grid ColumnDefinitions="*,auto" ColumnSpacing="10">
                    <Entry
                        x:Name="PasswordEntry"
                        Grid.Column="0"
                        FontSize="16"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"
                        Placeholder="Senha..."/>

                    <Button
                        Grid.Column="1"
                        x:Name="ViewPasswordButton"
                        HorizontalOptions="End"
                        HeightRequest="20"
                        WidthRequest="20"
                        CornerRadius="20"
                        BorderColor="{AppThemeBinding Light={StaticResource BorderStrong}, Dark={StaticResource DarkBorderStrong}}"
                        Margin="0,0,5,0"
                        Clicked="ViewPasswordButton_Clicked"/>
                </Grid>

                <Label
                    Text="Pergunta de segurança:"
                    Margin="5,20"
                    FontSize="16"/>

                <Picker
                    x:Name="SecurityQuestionPicker"
                    Title="Selecione uma pergunta de segurança"
                    ItemsSource="{Binding SecurityQuestions}"
                    FontSize="16"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"/>

                <Entry
                    x:Name="SecurityAnswerEntry"
                    Placeholder="Resposta de segurança..."
                    FontSize="16"
                    MaxLength="30"/>
            </VerticalStackLayout>
        </Border>

        <Button
            Text="Salvar"
            Clicked="SaveButton_Clicked"
            VerticalOptions="End"
            Margin="0,10"
            CornerRadius="10"
            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource DarkPrimaryLight}}"
            BorderColor="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource DarkBorderSoft}}"
            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"
            FontSize="18"
            FontAttributes="Bold"/>
    </VerticalStackLayout>
</ContentPage>
