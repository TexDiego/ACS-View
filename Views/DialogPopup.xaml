<?xml version="1.0" encoding="utf-8" ?>
<tk:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:tk="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:ACS_View.ViewModels"
    x:Name="RootPopup"
    x:Class="ACS_View.Views.DialogPopup"
    x:TypeArguments="x:Object"
    x:DataType="vm:DialogPopupViewModel"
    WidthRequest="{Binding PopupWidth}"
    CanBeDismissedByTappingOutsideOfPopup="True"
    BackgroundColor="Transparent"
    Padding="0">

    <Border
        Style="{StaticResource CardBorder}"
        Padding="14"
        Margin="0"
        StrokeShape="RoundRectangle 8">

        <VerticalStackLayout Spacing="14">
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="{Binding Title}"
                    Style="{StaticResource SectionTitle}"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap"/>

                <Label
                    Text="{Binding Message}"
                    Style="{StaticResource BodyMuted}"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap"
                    IsVisible="{Binding HasMessage}"/>
            </VerticalStackLayout>

            <Border
                Style="{StaticResource FieldBorder}"
                IsVisible="{Binding IsTextPrompt}">
                <Entry
                    x:Name="PromptEntry"
                    Text="{Binding InputText, Mode=TwoWay}"
                    Placeholder="{Binding Placeholder}"
                    MaxLength="{Binding MaxLength}"
                    Keyboard="{Binding Keyboard}"/>
            </Border>

            <VerticalStackLayout
                Spacing="8"
                BindableLayout.ItemsSource="{Binding Options}"
                IsVisible="{Binding HasOptions}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:DialogOption">
                        <Button
                            Text="{Binding Text}"
                            Style="{StaticResource GhostButton}"
                            CommandParameter="{Binding .}"
                            Clicked="OptionButton_Clicked">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsDestructive}" Value="True">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Accent}, Dark={StaticResource AccentLight}}"/>
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button
                    Text="{Binding SecondaryText}"
                    Style="{StaticResource GhostButton}"
                    IsVisible="{Binding HasSecondaryAction}"
                    Clicked="SecondaryButton_Clicked"/>

                <Button
                    Grid.Column="1"
                    Text="{Binding PrimaryText}"
                    Style="{StaticResource Buttons}"
                    IsVisible="{Binding HasPrimaryAction}"
                    Clicked="PrimaryButton_Clicked"/>
            </Grid>
        </VerticalStackLayout>
    </Border>
</tk:Popup>
