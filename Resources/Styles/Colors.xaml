<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#0084B1</Color>
    <Color x:Key="PrimaryDark">#006B91</Color>
    <Color x:Key="PrimaryLight">#DDF3FA</Color>
    <Color x:Key="Accent">#C93919</Color>
    <Color x:Key="AccentLight">#FBE9E4</Color>

    <Color x:Key="PageBackground">#FFFFFF</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceMuted">#F7FAFB</Color>
    <Color x:Key="TextPrimary">#1F2933</Color>
    <Color x:Key="TextSecondary">#5B6770</Color>
    <Color x:Key="TextMuted">#7A8790</Color>
    <Color x:Key="BorderSoft">#D7E1E7</Color>
    <Color x:Key="BorderStrong">#B7C7D0</Color>
    <Color x:Key="DisabledFill">#DCE5EA</Color>
    <Color x:Key="OverlayScrim">#80E6EBED</Color>

    <Color x:Key="DarkPageBackground">#181819</Color>
    <Color x:Key="DarkSurface">#17232D</Color>
    <Color x:Key="DarkSurfaceMuted">#1F2C36</Color>
    <Color x:Key="DarkTextPrimary">#EEF5F8</Color>
    <Color x:Key="DarkTextSecondary">#B7C7D0</Color>
    <Color x:Key="DarkTextMuted">#8FA2AD</Color>
    <Color x:Key="DarkBorderSoft">#2E4350</Color>
    <Color x:Key="DarkBorderStrong">#42606F</Color>
    <Color x:Key="DarkDisabledFill">#293946</Color>
    <Color x:Key="DarkPrimaryLight">#153E4B</Color>
    <Color x:Key="DarkAccentLight">#44231E</Color>
    <Color x:Key="DarkOverlayScrim">#99101820</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#1F2933</Color>
    <Color x:Key="Gray100">#F7FAFB</Color>
    <Color x:Key="Gray200">#E6EBED</Color>
    <Color x:Key="Gray300">#D7E1E7</Color>
    <Color x:Key="Gray400">#B7C7D0</Color>
    <Color x:Key="Gray500">#7A8790</Color>
    <Color x:Key="Gray600">#5B6770</Color>
    <Color x:Key="Gray900">#1F2933</Color>
    <Color x:Key="Gray950">#111827</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource DarkPrimaryLight}}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{AppThemeBinding Light={StaticResource AccentLight}, Dark={StaticResource DarkAccentLight}}"/>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{AppThemeBinding Light={StaticResource SurfaceMuted}, Dark={StaticResource DarkSurfaceMuted}}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}"/>
    <SolidColorBrush x:Key="BorderSoftBrush" Color="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource DarkBorderSoft}}"/>
</ResourceDictionary>
