<?xml version="1.0" encoding="utf-8" ?>
<tk:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:ACS_View.Domain.Entities"
    xmlns:tk="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="ACS_View.Views.VisitPage"
    x:TypeArguments="models:Visits"
    Color="Transparent">

    <Border
        Margin="16"
        Stroke="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource DarkBorderSoft}}"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 12"
        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
        Padding="16">

        <VerticalStackLayout x:Name="layoutGrid" Spacing="16">
            <VerticalStackLayout Spacing="4">
                <Label Text="Registrar visita" Style="{StaticResource PageTitle}" FontSize="22" HorizontalTextAlignment="Center"/>
                <Label Text="Informe o desfecho da visita" Style="{StaticResource BodyMuted}" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="Descricao" Spacing="4">
                <RadioButton GroupName="DescricaoVisita" Content="Realizada" IsChecked="True" CheckedChanged="RadioButton_CheckedChanged"/>
                <RadioButton GroupName="DescricaoVisita" Content="Ausente" CheckedChanged="RadioButton_CheckedChanged"/>
                <RadioButton GroupName="DescricaoVisita" Content="Recusada" CheckedChanged="RadioButton_CheckedChanged"/>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button
                    Text="Cancelar"
                    Style="{StaticResource GhostButton}"
                    Clicked="CancelButton_Clicked"/>

                <Button
                    Grid.Column="1"
                    x:Name="AddVisitButton"
                    Text="Registrar"
                    Style="{StaticResource PrimaryButton}"
                    Clicked="AddVisitButton_Clicked"/>
            </Grid>
        </VerticalStackLayout>
    </Border>
</tk:Popup>
