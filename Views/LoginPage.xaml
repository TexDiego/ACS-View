<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ACS_View.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             Style="{StaticResource PageBackground}">

    <Grid Padding="24" RowDefinitions="*,auto,*" MaximumWidthRequest="600">
        <VerticalStackLayout Grid.Row="1" Spacing="18">
            <Image
                Source="form.png"
                HeightRequest="112"
                WidthRequest="112"
                HorizontalOptions="Center"/>

            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                <Label Text="ACS View" Style="{StaticResource PageTitle}" HorizontalTextAlignment="Center"/>
                <Label Text="Acompanhamento comunitário" Style="{StaticResource BodyMuted}" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <Border Style="{StaticResource CardBorder}" Padding="18" Margin="0">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Login" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource FieldBorder}" Padding="12,0">
                            <Entry x:Name="UsernameEntry" HorizontalTextAlignment="Start"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Senha" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource FieldBorder}" Padding="12,0">
                            <Entry x:Name="PasswordEntry" IsPassword="True" HorizontalTextAlignment="Start"/>
                        </Border>
                    </VerticalStackLayout>

                    <Button
                        x:Name="Btn_Login"
                        Text="Entrar"
                        Style="{StaticResource PrimaryButton}"
                        Clicked="Btn_Login_Clicked"/>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button
                    x:Name="RegisterUser"
                    Grid.Column="0"
                    Text="Cadastre-se"
                    Style="{StaticResource GhostButton}"
                    Clicked="RegisterUser_Clicked"/>

                <Button
                    Grid.Column="1"
                    Text="Esqueci minha senha"
                    Style="{StaticResource GhostButton}"
                    TextColor="{AppThemeBinding Light={StaticResource Accent}, Dark={StaticResource AccentLight}}"
                    Clicked="Button_Clicked"/>
            </Grid>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
