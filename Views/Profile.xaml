<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             x:DataType="vm:ProfileViewModel"
             x:Class="ACS_View.Views.Profile"
             Style="{StaticResource PageBackground}"
             Title="{Binding DisplayName}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Sair" Command="{Binding LogoutCommand}"/>
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="14">
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Área pessoal" Style="{StaticResource SectionTitle}"/>
                    <Label Text="Acesse anotações e lembretes do seu acompanhamento." Style="{StaticResource BodyMuted}"/>
                    <Button Text="Abrir anotações"
                            Style="{StaticResource Buttons}"
                            Command="{Binding OpenNotesPage}"/>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Importação" Style="{StaticResource SectionTitle}"/>
                    <Label Text="Importe cadastros de pacientes e residências por planilha." Style="{StaticResource BodyMuted}"/>
                    <Button Text="Abrir importação"
                            Style="{StaticResource Buttons}"
                            Command="{Binding OpenImportDataPage}"/>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Dados" Style="{StaticResource SectionTitle}"/>
                    <Label Text="Apague registros associados apenas a este login." Style="{StaticResource BodyMuted}"/>
                    <Button Text="Gerenciar dados"
                            Style="{StaticResource Buttons}"
                            Command="{Binding OpenDataCleanupPage}"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
