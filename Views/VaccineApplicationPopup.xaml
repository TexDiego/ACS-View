<?xml version="1.0" encoding="utf-8" ?>
<tk:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:tk="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:ACS_View.ViewModels"
    xmlns:dto="clr-namespace:ACS_View.Application.DTOs"
    x:Class="ACS_View.Views.VaccineApplicationPopup"
    x:TypeArguments="dto:VaccineApplicationRequestDto"
    x:DataType="vm:VaccineApplicationPopupViewModel"
    WidthRequest="{Binding PopupWidth}"
    CanBeDismissedByTappingOutsideOfPopup="True"
    BackgroundColor="Transparent"
    Padding="0">

    <Border
        Style="{StaticResource CardBorder}"
        Padding="14"
        Margin="0"
        StrokeShape="RoundRectangle 8">

        <VerticalStackLayout Spacing="12">
            <VerticalStackLayout Spacing="4">
                <Label
                    Text="{Binding Title}"
                    Style="{StaticResource SectionTitle}"
                    HorizontalOptions="Center"/>

                <Label
                    Text="{Binding VaccineTitle}"
                    Style="{StaticResource CardTitle}"
                    HorizontalTextAlignment="Center"/>

                <Label
                    Text="{Binding RecommendedText}"
                    Style="{StaticResource BodyMuted}"
                    HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label Text="Data de aplicação" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource FieldBorder}">
                    <DatePicker
                        Date="{Binding ApplicationDate, Mode=TwoWay}"
                        MaximumDate="{Binding MaximumDate}"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label Text="Lote" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource FieldBorder}">
                    <Entry
                        Text="{Binding LotNumber, Mode=TwoWay}"
                        Placeholder="Opcional"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label Text="Observação" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource FieldBorder}">
                    <Editor
                        Text="{Binding Notes, Mode=TwoWay}"
                        Placeholder="Opcional"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="82"/>
                </Border>
            </VerticalStackLayout>

            <Label
                Text="{Binding ErrorMessage}"
                Style="{StaticResource BodyMuted}"
                TextColor="{AppThemeBinding Light={StaticResource Accent}, Dark={StaticResource AccentLight}}"
                IsVisible="{Binding HasError}"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button
                    Text="Cancelar"
                    Style="{StaticResource GhostButton}"
                    Clicked="CancelButton_Clicked"/>

                <Button
                    Grid.Column="1"
                    Text="Salvar"
                    Style="{StaticResource Buttons}"
                    Clicked="SaveButton_Clicked"/>
            </Grid>
        </VerticalStackLayout>
    </Border>
</tk:Popup>
