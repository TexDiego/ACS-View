<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_View.ViewModels"
             xmlns:model="clr-namespace:ACS_View.Domain.Entities"
             x:DataType="vm:AllVisitsViewModel"
             x:Class="ACS_View.Views.AllVisits"
             Shell.NavBarIsVisible="True"
             Style="{StaticResource PageBackground}"
             Title="Visitas">

    <Grid Padding="0" RowDefinitions="*,auto" RowSpacing="14">

        <CollectionView
            x:Name="VisitsCollectionView"
            Margin="{StaticResource PagePadding}"
            Grid.Row="0"
            ItemsSource="{Binding VisitsList}"
            ItemsUpdatingScrollMode="KeepLastItemInView"
            VerticalScrollBarVisibility="Never"
            Scrolled="CollectionView_Scrolled">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:Visits">
                    <Border Style="{StaticResource CardBorder}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToHouseCommand}"
                                CommandParameter="{Binding Id}" />
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="*,44" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label
                                    Text="{Binding Date, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                    Style="{StaticResource CardTitle}"/>

                                <Label
                                    Text="{Binding Address}"
                                    Style="{StaticResource BodyMuted}"/>

                                <Label
                                    Text="{Binding Description}"
                                    TextColor="{AppThemeBinding Light={StaticResource Accent}, Dark={StaticResource AccentLight}}"
                                    FontSize="13"
                                    FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <ImageButton
                                Grid.Column="1"
                                Source="bin"
                                HeightRequest="25"
                                WidthRequest="25"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteVisit}"
                                CommandParameter="{Binding Id}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout
            Spacing="10"
            Grid.Row="1">

            <Label Text="Sugestões de visitas" Style="{StaticResource SectionTitle}" HorizontalOptions="Center" Margin="10,5,10,0"/>

            <CarouselView
                ItemsSource="{Binding HouseList}"
                IsBounceEnabled="True"
                IsSwipeEnabled="{Binding CanSwipe}"
                Loop="True"
                HeightRequest="112"
                Margin="0,5">

                <CarouselView.ItemTemplate>
                    <DataTemplate x:DataType="model:House">
                        <Border
                            Stroke="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource DarkBorderSoft}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceMuted}, Dark={StaticResource DarkSurfaceMuted}}"
                            StrokeShape="RoundRectangle 8"
                            Padding="12"
                            Margin="4,0">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToHouseCommand}"
                                    CommandParameter="{Binding CasaId}" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                <Label Text="{Binding Rua}" Style="{StaticResource CardTitle}" FontSize="15"/>
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="Número" Style="{StaticResource BodyMuted}"/>
                                    <Label Text="{Binding NumeroCasa}" Style="{StaticResource BodyMuted}" FontAttributes="Bold"/>
                                </HorizontalStackLayout>
                                <Label
                                    Text="{Binding Complemento}"
                                    IsVisible="{Binding PossuiComplemento}"
                                    Style="{StaticResource BodyMuted}"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CarouselView.ItemTemplate>

                <CarouselView.EmptyView>
                    <Label
                        Style="{StaticResource FieldLabel}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Text="Todas as residências foram visitadas este mês!"/>
                </CarouselView.EmptyView>
            </CarouselView>
        </VerticalStackLayout>

        <ImageButton
            x:Name="BackToTopButton"
            Grid.RowSpan="2"
            Style="{StaticResource FloatingBackToTopButton}"
            Clicked="BackToTopButton_Clicked"/>
    </Grid>
</ContentPage>
